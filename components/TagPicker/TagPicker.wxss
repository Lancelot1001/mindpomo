/* components/TagPicker/TagPicker.wxss */

/* 遮罩 */
.tag-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all var(--transition-normal);
}

.tag-picker-mask.show {
  opacity: 1;
  visibility: visible;
}

/* 弹窗内容 */
.tag-picker-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 32rpx;
  transform: translateY(100%);
  transition: transform var(--transition-normal) ease-out;
}

.tag-picker-content.show {
  transform: translateY(0);
}

/* 标题 */
.picker-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.picker-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--text-primary);
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  background: var(--card);
  border: 2rpx solid var(--border);
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.tag-item.selected {
  background: var(--primary);
  border-color: var(--primary);
  color: #FFFFFF;
}

.add-tag {
  border-style: dashed;
  color: var(--primary);
}

/* 开始按钮 */
.btn-start {
  width: 100%;
  height: 96rpx;
  font-size: var(--font-size-base);
  font-weight: 600;
  border-radius: 48rpx;
  background: var(--primary);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-start:active {
  background: var(--primary-dark);
}