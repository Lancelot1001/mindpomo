/* pages/stats/stats.wxss */

/* 容器 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  background: var(--bg);
}

/* 卡片 */
.card {
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.card-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* 进度条 */
.progress-bar {
  height: 12rpx;
  background: var(--primary-bg);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-bar.small {
  height: 8rpx;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-light));
  border-radius: 6rpx;
  transition: width var(--transition-normal);
}

/* 进度文字 */
.progress-text {
  display: flex;
  justify-content: flex-end;
  font-size: var(--font-size-sm);
}

.progress-text .current {
  color: var(--text-primary);
  font-weight: 600;
}

.progress-text .goal {
  color: var(--text-tertiary);
}

.progress-text.small {
  font-size: var(--font-size-xs);
  color: var(--text-tertiary);
}

/* 本周卡片 */
.week-card {
  /* 样式已在通用card中定义 */
}

/* 今日卡片 */
.today-stats {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.stat-value {
  font-size: var(--font-size-2xl);
  font-weight: 600;
  color: var(--text-primary);
}

.stat-label {
  font-size: var(--font-size-sm);
  color: var(--text-tertiary);
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--border);
  margin: 0 48rpx;
}

/* 标签分布 */
.tags-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tag-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tag-name {
  width: 80rpx;
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.tag-bar-wrapper {
  flex: 1;
  height: 16rpx;
  background: var(--primary-bg);
  border-radius: 8rpx;
  overflow: hidden;
}

.tag-bar {
  height: 100%;
  background: var(--primary);
  border-radius: 8rpx;
}

.tag-percentage {
  width: 60rpx;
  font-size: var(--font-size-sm);
  color: var(--text-tertiary);
  text-align: right;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 48rpx;
  color: var(--text-tertiary);
  font-size: var(--font-size-sm);
}