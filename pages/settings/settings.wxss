/* pages/settings/settings.wxss */

/* 容器 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  background: var(--bg);
}

/* 卡片 */
.card {
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.setting-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.setting-icon {
  font-size: 40rpx;
}

.setting-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--text-primary);
}

.setting-content {
  /* 内容区域 */
}

/* 滑块 */
.slider-wrapper {
  margin-bottom: 16rpx;
}

.slider-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  font-size: var(--font-size-xs);
  color: var(--text-tertiary);
}

.current-value {
  text-align: center;
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--primary);
}

/* 休息设置 */
.break-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.break-item:last-of-type {
  border-bottom: none;
}

.break-label {
  font-size: var(--font-size-base);
  color: var(--text-primary);
}

.break-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.break-value {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-lg);
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 50%;
  font-weight: 600;
}

.break-value-text {
  font-size: var(--font-size-base);
  color: var(--text-primary);
  min-width: 120rpx;
  text-align: center;
}

.break-hint {
  font-size: var(--font-size-xs);
  color: var(--text-tertiary);
  margin-top: 16rpx;
  text-align: center;
}

/* 开关 */
.toggle-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.toggle-item:last-child {
  border-bottom: none;
}

.toggle-label {
  font-size: var(--font-size-base);
  color: var(--text-primary);
}

/* 操作项 */
.action-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.action-item:last-child {
  border-bottom: none;
}

.action-label {
  font-size: var(--font-size-base);
  color: var(--text-primary);
}

.action-arrow {
  font-size: var(--font-size-base);
  color: var(--text-tertiary);
}

.action-item.danger .action-label {
  color: var(--error);
}

/* 关于 */
.about-section {
  text-align: center;
  padding: 48rpx 0;
}

.about-text {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}